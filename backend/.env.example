# ── CyberAce backend configuration ──────────────────────────────
# Copy this file to `.env` and adjust as needed.

# Port the API listens on
PORT=4000

# Comma-separated list of allowed CORS origins (the frontend URL)
CLIENT_ORIGIN=http://localhost:3000

# MongoDB connection string.
# Leave EMPTY to let the server spin up an in-memory MongoDB automatically
# (great for a zero-setup demo). Set a real URI for persistence:
#   MONGODB_URI=mongodb://127.0.0.1:27017/cyberace
#   MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cyberace
MONGODB_URI=

# Force the in-memory MongoDB even if MONGODB_URI is set (true/false)
USE_MEMORY_DB=false

# JWT secret — CHANGE THIS in production
JWT_SECRET=change-me-cyberace-dev-secret
JWT_EXPIRES_IN=7d

# Auto-seed the database with courses/challenges on startup if empty (true/false)
AUTO_SEED=true

# ── Docker sandbox (labs cyber-pratique) ────────────────────────
# Laisser VIDE pour utiliser le démon Docker local (socket / named pipe).
# Sinon, pointer vers un démon distant en TCP — utile quand l'hôte ne peut
# pas faire tourner Docker Desktop (ex. démon dans une VM VirtualBox) :
#   DOCKER_HOST=tcp://192.168.1.48:2375
# ⚠ Sans TLS : UNIQUEMENT sur un réseau local privé de confiance.
DOCKER_HOST=
# Hôte que le NAVIGATEUR doit joindre pour les ports publiés des conteneurs
# (terminal web ttyd). Vide = déduit de DOCKER_HOST (ou localhost en local).
#   SANDBOX_PUBLIC_HOST=192.168.1.48
SANDBOX_PUBLIC_HOST=

# Construire les images des labs : `npx ts-node --transpile-only scripts/build-images.ts`
# (respecte DOCKER_HOST ; build toutes les images ou une liste ciblée en args)

# ── Compilateur en ligne pour les défis C (TP) ──────────────────
# Le bouton « Compiler & Exécuter » des défis "code" en C délègue la
# compilation à un sandbox externe. Défaut : Wandbox (public, sans clé).
# Le SCORING ne dépend PAS de ce service (correction par points-clés, hors-ligne).
# Pour auto-héberger, pointe vers une instance Piston/Wandbox :
#   CODE_EXEC_URL=https://wandbox.org/api/compile.json
#   CODE_EXEC_COMPILER=gcc-13.2.0
CODE_EXEC_URL=https://wandbox.org/api/compile.json
CODE_EXEC_COMPILER=gcc-13.2.0
