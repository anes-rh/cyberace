{
  "name": "cyberace-backend",
  "version": "1.0.0",
  "description": "CyberAce — API REST (Express + Mongoose + JWT) pour la plateforme de courses de cybersécurité",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "ts-node --transpile-only src/data/seed.ts",
    "sandbox:prune": "ts-node --transpile-only scripts/prune-sandboxes.ts"
  },
  "keywords": [
    "cybersecurity",
    "ctf",
    "express",
    "mongoose",
    "jwt"
  ],
  "author": "CyberAce",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dockerode": "^5.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "mongodb-memory-server": "^11.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
